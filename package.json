{
  "name": "weatherwear-backend",
  "version": "2.0.0",
  "description": "WeatherWear — Node.js/Express + Supabase Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "frontend": "npm start --prefix frontend",
    "dev:all": "concurrently -n backend,frontend -c blue,cyan \"npm run dev\" \"npm run frontend\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
